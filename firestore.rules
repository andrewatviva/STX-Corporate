rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isSTX() {
      return isAuthenticated() && (
        request.auth.token.role == 'stx_admin' ||
        request.auth.token.role == 'stx_ops'
      );
    }

    function isSTXAdmin() {
      return isAuthenticated() && request.auth.token.role == 'stx_admin';
    }

    function isClientMember(clientId) {
      return isAuthenticated() && request.auth.token.clientId == clientId;
    }

    function isClientOps(clientId) {
      return isClientMember(clientId) && (
        request.auth.token.role == 'client_ops' ||
        request.auth.token.role == 'client_approver'
      );
    }

    function isClientWriter(clientId) {
      return isClientMember(clientId) && (
        request.auth.token.role == 'client_ops' ||
        request.auth.token.role == 'client_approver' ||
        request.auth.token.role == 'client_traveller'
      );
    }

    // Client root document (name, active status) — STX can list all clients
    match /clients/{clientId} {
      allow read:  if isSTX() || isClientMember(clientId);
      allow write: if isSTXAdmin();
    }

    // Tenant config — readable by own client and STX; writable only by STX admin
    match /clients/{clientId}/config/{doc} {
      allow read:  if isSTX() || isClientMember(clientId);
      allow write: if isSTXAdmin();
    }

    // Trips — all client roles can create/update; only STX admin can delete
    match /clients/{clientId}/trips/{tripId} {
      allow read:   if isSTX() || isClientMember(clientId);
      allow create: if isSTX() || isClientWriter(clientId);
      allow update: if isSTX() || isClientWriter(clientId);
      allow delete: if isSTXAdmin();
    }

    // collectionGroup('trips') used by STX staff to query across all tenants
    match /{path=**}/trips/{tripId} {
      allow read: if isSTX();
    }

    // Passengers
    match /clients/{clientId}/passengers/{passengerId} {
      allow read:  if isSTX() || isClientMember(clientId);
      allow write: if isSTX() || isClientOps(clientId);
    }

    // Invoices — generated by STX only
    match /clients/{clientId}/invoices/{invoiceId} {
      allow read:  if isSTX() || isClientMember(clientId);
      allow write: if isSTX();
    }

    // User profiles
    match /users/{userId} {
      allow read:  if isSTX() || request.auth.uid == userId;
      allow write: if isSTXAdmin();
      allow update: if request.auth.uid == userId &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['role', 'clientId', 'active', 'permissionOverrides']);
    }

    // STX global config
    match /stx/{document=**} {
      allow read:  if isSTX();
      allow write: if isSTXAdmin();
    }

    // Trip feedback / provider ratings — any authenticated user can read (global anonymised report)
    // and write their own rating (ratedBy must match the requester's UID)
    match /tripFeedback/{docId} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.ratedBy == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.ratedBy == request.auth.uid;
    }

    // Portal feedback / fault reports — any authenticated user can submit; only STX can read
    match /portalFeedback/{docId} {
      allow create: if isAuthenticated();
      allow read:   if isSTX();
      allow update: if isSTXAdmin();
    }

    // Email queue — authenticated users can enqueue; only STX can read/delete
    match /emailQueue/{docId} {
      allow create: if isAuthenticated();
      allow read:   if isSTX();
      allow delete: if isSTX();
    }

    // Client onboarding forms — token serves as access control (32-char random hex)
    // Anyone with the URL can read and submit; only STX can create/delete/manage
    match /onboarding/{token} {
      allow read:   if true;
      allow create: if isSTX();
      allow update: if (resource.data.status == 'pending' && request.resource.data.status == 'submitted') ||
                       isSTX();
      allow delete: if isSTXAdmin();
    }
  }
}
